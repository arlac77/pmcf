#!/usr/bin/env node
import { extendingAttributeIterator } from "pacc";
import { prepare } from "../src/cli.mjs";

const { root, args, options } = await prepare({});

for (const expression of args) {
  const result = root.named(expression);

  show(result);
}

function show(value, indent = 0, short = false) {
  if (value instanceof Iterator) {
    for (const v of value) {
      show(v, indent);
    }
  } else {
    const type = value.constructor;
    const prefix = (l = indent) => " ".repeat(l * 2);
    const ml = maxNameLength(type);
    const name = (attribute, l = indent + 1) =>
      prefix(l) + attribute.name.padEnd(ml) + ": ";

    if (short) {
      console.log(`${prefix()}${value[type.key]}:`);
    } else {
      console.log(`${prefix()}${value.fullName}(${type.name}):`);
    }

    for (const [path, attribute] of extendingAttributeIterator(
      type,
      attribute =>
        !attribute.key && !attribute.private && attribute.type.primitive
    )) {
      const v = value.attribute(attribute.name);
      if (v !== undefined) {
        if (attribute.collection) {
          const l = [...v];
          if (l.length) {
            console.log(`${name(attribute)}${l}`);
          }
        } else {
          console.log(`${name(attribute)}${v}`);
        }
      }
    }

    for (const [path, attribute] of extendingAttributeIterator(
      type,
      attribute => !attribute.private && !attribute.type.primitive
    )) {
      const v = value[attribute.name];
      if (v !== undefined) {
        if (attribute.collection) {
          if (attribute.backpointer) {
            console.log(name(attribute));
            for (const o of v.values()) {
              show(o, indent + 2, true);
            }
          } else {
            const l = [...v];

            if (l.length > 1) {
              console.log(name(attribute));

              for (const o of l) {
                console.log(prefix(indent + 2) + o.fullName);
              }
            } else if (l.length === 1) {
              console.log(name(attribute) + l[0].fullName);
            }
          }
        } else {
          console.log(`${name(attribute)}${v.fullName}`);
        }
      }
    }
  }
}

function maxNameLength(type) {
  let maxLength = 0;
  for (const [path, attribute] of extendingAttributeIterator(
    type,
    attribute => !attribute.key && !attribute.private
  )) {
    maxLength = Math.max(maxLength, attribute.name.length);
  }

  return maxLength;
}
