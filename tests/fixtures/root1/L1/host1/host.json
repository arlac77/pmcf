{
  "priority": 11,
  "os": "linux",
  "depends": ["d1", "d2-${os}"],
  "replaces": ["r1", "r2-${os}"],
  "provides": ["p1", "p2-${os}"],
  "extends": ["/model/m1", "/model/${os}", "/templates/arch-linux"],
  "networkInterfaces": {
    "eth0": {
      "kind": "ethernet",
      "network": "/L1/n1",
      "ipAddresses": "192.168.1.1"
    }
  },
  "services": {
    "alpm": {
      "repositories": {
        "mf-private": {
          "base": "/binaries/linux/arch/$repo/$arch",
          "architectures": ["aarch64", "x86", "armv7"]
        },
        "mf-public": {
          "base": "/binaries/linux/arch/$repo/$arch",
          "architectures": ["aarch64", "x86", "armv7"]
        }
      }
    },
    "influxdb": {},
    "postfix": {
      "extends": "/templates/postfix"
    },
    "timemachine": {
      "extends": "/templates/timemachine"
    },
    "mosquitto": {
      "extends": "/templates/mosquitto",
      "acl_file": "/etc/mosquitto/acl"
    },
    "dns": { "alias": "dns" },
    "openldap": {
      "extends": "/templates/openldap",
      "alias": "ldap",
      "base": "${ldap_base}",
      "uri": "ldap://"
    },
    "chrony": {
      "alias": "ntp",
      "source": "/GLOBAL"
    }
  }
}
